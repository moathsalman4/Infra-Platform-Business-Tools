# ---------- Terraform ----------
# Local Terraform working dirs (provider binaries, module cache)
**/.terraform/
**/.terraform.lock.hcl.bak

# Terraform state files (we use S3 backend, but defensive)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Override files (local-only customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# ---------- macOS ----------
.DS_Store

# ---------- Editors ----------
.vscode/
.idea/
*.swp
*~